# Environment Variables for webGrabber

# Server
PORT=3000

# Logging
# LOG_LEVEL=info
CONSOLE_LOG_LEVEL=error

# Rate limiting (server mode)
SERVER_RATE_LIMIT_WINDOW_MS=900000
SERVER_RATE_LIMIT_MAX_REQUESTS=100

# Agent mode (optional — npm run start:agent)
# AGENT_REASON_MODEL=gemma4:latest
# AGENT_VISION_MODEL=minicpm-v4.6:latest
# AGENT_VISION=true
# AGENT_OLLAMA_URL=http://localhost:11434/v1
# AGENT_ALLOWED_HOSTS=example.com,github.com
# AGENT_MAX_STEPS=30
# AGENT_HTML_PAGE_SIZE=100000
# AGENT_CACHE_OBSERVATIONS=true
# AGENT_REASON_THINKING=true
# AGENT_REASONING_EFFORT=medium

# Grab variables (available in grabs as {{VARIABLE_NAME}})
# GRABBER_USERNAME=
# GRABBER_PASSWORD=
# GRABBER_API_KEY=
