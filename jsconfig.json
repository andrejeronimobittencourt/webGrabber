{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "paths": {
      "#core": [
        "./packages/core/index.js"
      ],
      "#core/*": [
        "./packages/core/*"
      ]
    }
  },
