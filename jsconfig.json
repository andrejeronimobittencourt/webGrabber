{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"jsx": "react",
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"paths": {
			"@webgrabber/core": ["./packages/core/index.js"],
			"@webgrabber/core/*": ["./packages/core/*"]
		}
	},
	"exclude": [
		"node_modules",
		"**/node_modules/*"
	]
}
